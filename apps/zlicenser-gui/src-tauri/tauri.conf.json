{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "zlicenser",
  "version": "0.1.0",
  "identifier": "com.zal-analytics.zlicenser",
  "build": {
    "beforeDevCommand": "npm run dev --prefix ../frontend",
    "beforeBuildCommand": "npm run build --prefix ../frontend",
    "frontendDist": "../frontend/build",
    "devUrl": "http://localhost:5173"
  },
  "app": {
    "windows": [
      {
        "title": "zlicenser",
        "width": 800,
        "height": 600
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
